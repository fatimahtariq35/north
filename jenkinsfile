pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/your-username/landing-page.git'
            }
        }

        stage('Install') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t landing-page .'
            }
        }

        stage('Run') {
            steps {
                sh 'docker run -d -p 3000:3000 landing-page'
            }
        }
    }
}
