pipeline {
    agent any

    environment {
        EC2_IP = '13.233.100.9'
        DEPLOY_PATH = '/var/www/north/build'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/fatimahtariq35/north.git'
            }
        }

        stage('Install') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Deploy') {
            steps {
                sh """
                rsync -avz --delete build/ ubuntu@${EC2_IP}:${DEPLOY_PATH}
                """
            }
        }

        stage('Reload Nginx') {
            steps {
                sh """
                ssh ubuntu@${EC2_IP} 'sudo systemctl reload nginx'
                """
            }
        }
    }

    post {
        success {
            echo '✅ Deployment successful! App is live'
        }
        failure {
            echo '❌ Deployment failed'
        }
    }
}
